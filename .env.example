# --- 1. Database Configuration ---
# 로컬 개발 시에는 localhost, 운영 시에는 db 서비스명(컨테이너 이름) 입력
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/jidogam
SPRING_DATASOURCE_USERNAME=jidogam
SPRING_DATASOURCE_PASSWORD=your_password_here

# --- 2. External API Keys ---
# 지역 정보 서비스 관련 키 (SGIS API 등)
AREA_SERVICE_ID=your_service_id
AREA_SECRET_KEY=your_secret_key

# --- 3. Business Logic & Policy Settings ---
# 스탬프 획득 쿨타임 (예: 5s, 10m, 1h)
STAMP_COOLDOWN_TIME=5s
# 비밀번호 재설정 토큰 유효 시간 (예: 15m)
PASSWORD_RESET_TOKEN_EXPIRATION=15m
# 이메일 인증 코드 유효 시간 (예: 3m)
EMAIL_AUTH_CODE_EXPIRATION=3m

# --- 4. Security & Authentication ---
# HS256 알고리즘 기준 최소 32자 이상의 랜덤 문자열 권장
JWT_SECRET=your_jwt_secret_key_random_string_here

# 이메일 링크 발송용 프론트엔드 주소 (예: https://jidogam.vercel.app)
FRONTEND_URL=http://localhost:3000

# --- 5. Email Service (SMTP) ---
# 알림 및 인증 메일 발송용 계정
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# --- 6. Storage Settings ---
# 선택 가능 값: local, oci, s3
STORAGE_TYPE=oci

# [AWS S3 - STORAGE_TYPE=s3 인 경우 필수]
S3_ACCESS_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# [OCI - STORAGE_TYPE=oci 인 경우 필수]
OCI_NAMESPACE=
OCI_REGION=
OCI_ACCESS_KEY=
OCI_SECRET_KEY=
OCI_BUCKET=

# --- 7. Initial Admin Account (Data Seeding) ---
# 서버 시작 시 DB에 자동 생성될 초기 관리자 정보
ADMIN_EMAIL=admin@jidogam.com
ADMIN_PASSWORD=admin_password_1234
ADMIN_NICKNAME=관리자

# --- 8. Management & Monitoring (Actuator) ---
# 서버 상태 모니터링 기본 경로 (기본값: /actuator)
# 보안을 위해 운영 시 /mgmt 등으로 변경 권장
MGMT_PATH=/actuator